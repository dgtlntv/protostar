{
    "$schema": "./commands-schema.json",
    "welcome": "Coverage CLI — exercises every component variant for 2.F.5 parity comparison. Type `demo --help` to list groups.",
    "variables": {
        "declaredVar": "initial",
        "flag": "true"
    },
    "commands": {
        "demo": {
            "description": "Parent command grouping every component-coverage demo.",
            "commands": {
                "text-plain": {
                    "description": "Plain text component with no duration.",
                    "handler": [
                        {
                            "component": "text",
                            "output": "Plain text line — no duration."
                        }
                    ]
                },
                "text-duration": {
                    "description": "Text component that pauses before printing.",
                    "handler": [
                        {
                            "component": "text",
                            "output": "Pausing 800ms before this line prints…",
                            "duration": 800
                        },
                        {
                            "component": "text",
                            "output": "…printed after the pause."
                        }
                    ]
                },
                "text-interp": {
                    "description": "Text with variable interpolation.",
                    "handler": [
                        {
                            "component": "text",
                            "output": "declaredVar = {{declaredVar}}; flag = {{flag}}"
                        }
                    ]
                },
                "progress": {
                    "description": "Progress bar over 1500ms.",
                    "handler": [
                        {
                            "component": "progressBar",
                            "output": "Working…",
                            "duration": 1500
                        },
                        {
                            "component": "text",
                            "output": "Progress complete."
                        }
                    ]
                },
                "spinner-single": {
                    "description": "Spinner with a single phrase.",
                    "handler": [
                        {
                            "component": "spinner",
                            "output": "Loading single phrase…",
                            "duration": 1500
                        },
                        {
                            "component": "text",
                            "output": "Single-phrase spinner finished."
                        }
                    ]
                },
                "spinner-multi": {
                    "description": "Spinner cycling through an array of phrases.",
                    "handler": [
                        {
                            "component": "spinner",
                            "output": [
                                "Step one",
                                "Step two",
                                "Step three"
                            ],
                            "duration": 3000
                        },
                        {
                            "component": "text",
                            "output": "Multi-phrase spinner finished."
                        }
                    ]
                },
                "table-auto": {
                    "description": "Table with auto-fit column widths.",
                    "handler": [
                        {
                            "component": "table",
                            "output": [
                                ["ID", "Name", "Role"],
                                ["1", "Ada", "Engineer"],
                                ["2", "Linus", "Maintainer"],
                                ["3", "Grace", "Architect"]
                            ]
                        }
                    ]
                },
                "table-fixed": {
                    "description": "Table with explicit colWidths.",
                    "handler": [
                        {
                            "component": "table",
                            "colWidths": [6, 14, 20],
                            "output": [
                                ["ID", "Name", "Notes"],
                                [
                                    "1",
                                    "Ada Lovelace",
                                    "Wrote the first algorithm intended for a machine."
                                ],
                                [
                                    "2",
                                    "Linus Torvalds",
                                    "Created Linux and Git."
                                ]
                            ]
                        }
                    ]
                },
                "conditional-true": {
                    "description": "Conditional that takes the `then` branch (flag == 'true').",
                    "handler": [
                        {
                            "component": "conditional",
                            "output": {
                                "if": "flag == 'true'",
                                "then": {
                                    "component": "text",
                                    "output": "Took the THEN branch."
                                },
                                "else": {
                                    "component": "text",
                                    "output": "Took the ELSE branch."
                                }
                            }
                        }
                    ]
                },
                "conditional-false": {
                    "description": "Conditional that takes the `else` branch (flag == 'false').",
                    "handler": [
                        {
                            "component": "conditional",
                            "output": {
                                "if": "flag == 'false'",
                                "then": {
                                    "component": "text",
                                    "output": "Took the THEN branch."
                                },
                                "else": {
                                    "component": "text",
                                    "output": "Took the ELSE branch."
                                }
                            }
                        }
                    ]
                },
                "conditional-nested": {
                    "description": "Conditional nested inside another conditional.",
                    "handler": [
                        {
                            "component": "conditional",
                            "output": {
                                "if": "flag == 'true'",
                                "then": {
                                    "component": "conditional",
                                    "output": {
                                        "if": "declaredVar == 'initial'",
                                        "then": {
                                            "component": "text",
                                            "output": "Outer THEN, inner THEN."
                                        },
                                        "else": {
                                            "component": "text",
                                            "output": "Outer THEN, inner ELSE."
                                        }
                                    }
                                },
                                "else": {
                                    "component": "text",
                                    "output": "Outer ELSE."
                                }
                            }
                        }
                    ]
                },
                "var-declared": {
                    "description": "Set a declared variable and read it back.",
                    "handler": [
                        {
                            "component": "variable",
                            "output": { "declaredVar": "updated" }
                        },
                        {
                            "component": "text",
                            "output": "declaredVar is now {{declaredVar}}"
                        }
                    ]
                },
                "var-undeclared": {
                    "description": "Attempt to set an undeclared variable; should be rejected.",
                    "handler": [
                        {
                            "component": "variable",
                            "output": { "neverDeclared": "value" }
                        },
                        {
                            "component": "text",
                            "output": "If you see this, the rejection did not crash the handler."
                        }
                    ]
                },
                "input": {
                    "description": "Plain text input prompt.",
                    "handler": [
                        {
                            "component": "input",
                            "name": "answer",
                            "message": "Type anything:"
                        },
                        {
                            "component": "text",
                            "output": "You typed: {{answer}}"
                        }
                    ]
                },
                "number": {
                    "description": "Numeric input prompt.",
                    "handler": [
                        {
                            "component": "number",
                            "name": "n",
                            "message": "Enter a number:"
                        },
                        {
                            "component": "text",
                            "output": "n = {{n}}"
                        }
                    ]
                },
                "password": {
                    "description": "Masked password prompt.",
                    "handler": [
                        {
                            "component": "password",
                            "name": "pw",
                            "message": "Enter a password (masked):"
                        },
                        {
                            "component": "text",
                            "output": "Captured password: {{pw}}"
                        }
                    ]
                },
                "invisible": {
                    "description": "Invisible (no echo) prompt.",
                    "handler": [
                        {
                            "component": "invisible",
                            "name": "secret",
                            "message": "Enter something invisibly:"
                        },
                        {
                            "component": "text",
                            "output": "Captured invisible value: {{secret}}"
                        }
                    ]
                },
                "list": {
                    "description": "Comma-separated list input.",
                    "handler": [
                        {
                            "component": "list",
                            "name": "items",
                            "message": "Enter comma-separated items:"
                        },
                        {
                            "component": "text",
                            "output": "items = {{items}}"
                        }
                    ]
                },
                "select": {
                    "description": "Single-pick select prompt.",
                    "handler": [
                        {
                            "component": "select",
                            "name": "color",
                            "message": "Pick a color:",
                            "choices": [
                                { "name": "Red", "value": "red" },
                                { "name": "Green", "value": "green" },
                                { "name": "Blue", "value": "blue" }
                            ]
                        },
                        {
                            "component": "text",
                            "output": "color = {{color}}"
                        }
                    ]
                },
                "autocomplete": {
                    "description": "Type-to-filter autocomplete prompt.",
                    "handler": [
                        {
                            "component": "autoComplete",
                            "name": "fruit",
                            "message": "Pick a fruit:",
                            "choices": [
                                "apple",
                                "apricot",
                                "banana",
                                "blackberry",
                                "blueberry",
                                "cherry",
                                "date",
                                "fig",
                                "grape",
                                "kiwi",
                                "lemon"
                            ],
                            "limit": 5,
                            "footer": "type to filter"
                        },
                        {
                            "component": "text",
                            "output": "fruit = {{fruit}}"
                        }
                    ]
                },
                "multiselect": {
                    "description": "Multi-pick prompt.",
                    "handler": [
                        {
                            "component": "multiSelect",
                            "name": "tags",
                            "message": "Pick zero or more tags:",
                            "choices": [
                                { "name": "Bug", "value": "bug" },
                                { "name": "Feature", "value": "feature" },
                                { "name": "Chore", "value": "chore" },
                                { "name": "Docs", "value": "docs" }
                            ]
                        },
                        {
                            "component": "text",
                            "output": "tags = {{tags}}"
                        }
                    ]
                },
                "confirm": {
                    "description": "Yes/no confirmation prompt.",
                    "handler": [
                        {
                            "component": "confirm",
                            "name": "ok",
                            "message": "Continue?",
                            "initial": true
                        },
                        {
                            "component": "text",
                            "output": "ok = {{ok}}"
                        }
                    ]
                },
                "form": {
                    "description": "Multi-field form prompt.",
                    "handler": [
                        {
                            "component": "form",
                            "name": "profile",
                            "message": "Fill out your profile:",
                            "choices": [
                                {
                                    "name": "firstName",
                                    "message": "First name",
                                    "initial": "Ada"
                                },
                                {
                                    "name": "lastName",
                                    "message": "Last name",
                                    "initial": "Lovelace"
                                },
                                {
                                    "name": "email",
                                    "message": "Email"
                                }
                            ]
                        },
                        {
                            "component": "text",
                            "output": "Submitted profile."
                        }
                    ]
                },
                "basicauth": {
                    "description": "Basic-auth challenge (admin / hunter2).",
                    "handler": [
                        {
                            "component": "basicAuth",
                            "name": "authed",
                            "message": "Authenticate:",
                            "username": "admin",
                            "password": "hunter2"
                        },
                        {
                            "component": "text",
                            "output": "authed = {{authed}}"
                        }
                    ]
                },
                "toggle": {
                    "description": "Two-state toggle prompt.",
                    "handler": [
                        {
                            "component": "toggle",
                            "name": "darkMode",
                            "message": "Dark mode?",
                            "enabled": "On",
                            "disabled": "Off"
                        },
                        {
                            "component": "text",
                            "output": "darkMode = {{darkMode}}"
                        }
                    ]
                },
                "sort": {
                    "description": "Reorder a list.",
                    "handler": [
                        {
                            "component": "sort",
                            "name": "ranking",
                            "message": "Reorder these items:",
                            "choices": ["alpha", "bravo", "charlie", "delta"]
                        },
                        {
                            "component": "text",
                            "output": "ranking = {{ranking}}"
                        }
                    ]
                },
                "snippet": {
                    "description": "Fill ${name} placeholders in a template.",
                    "handler": [
                        {
                            "component": "snippet",
                            "name": "snippetResult",
                            "message": "Configure a release tag:",
                            "fields": [
                                {
                                    "name": "version",
                                    "message": "Semver version (e.g. 1.2.3)"
                                },
                                {
                                    "name": "channel",
                                    "message": "Release channel"
                                }
                            ],
                            "template": "v${version}-${channel}"
                        },
                        {
                            "component": "text",
                            "output": "tag = {{snippetResult}}"
                        }
                    ]
                }
            }
        }
    }
}
