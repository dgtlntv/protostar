{
    "name": "protostar-monorepo",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "packageManager": "pnpm@11.0.8",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "build:lib": "pnpm --filter @dgtlntv/protostar build:lib",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:unit": "pnpm -r test:unit",
        "test:unit:ui": "pnpm --filter @dgtlntv/protostar test:unit:ui",
        "typecheck": "pnpm -r typecheck"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@types/node": "^25.6.0",
        "vite": "^8.0.11"
    },
    "dependencies": {
        "@dgtlntv/protostar": "workspace:*",
        "@xterm/xterm": "^6.0.0"
    },
    "license": "GPL-3.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/dgtlntv/protostar.git"
    }
}
