{
    "name": "@dgtlntv/protostar",
    "version": "0.0.1",
    "type": "module",
    "main": "dist/index.umd.js",
    "module": "dist/index.es.js",
    "exports": {
        ".": {
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "build:lib": "vite build --mode lib",
        "prepublishOnly": "npm run build:lib",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:unit": "vitest run",
        "test:unit:ui": "vitest --ui",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@types/node": "^25.6.0",
        "@types/shell-quote": "^1.7.5",
        "@vitest/ui": "^4.1.5",
        "@xterm/headless": "^6.0.0",
        "typescript": "^6.0.3",
        "vite": "^5.3.1",
        "vitest": "^4.1.5"
    },
    "dependencies": {
        "@mariozechner/pi-tui": "^0.73.0",
        "@xterm/addon-fit": "^0.10.0",
        "@xterm/xterm": "^5.5.0",
        "ansi-escapes": "^7.0.0",
        "ansi-regex": "^6.0.1",
        "chalk": "^5.3.0",
        "cli-spinners": "^3.1.0",
        "cliui": "^8.0.1",
        "command-line-usage": "^7.0.3",
        "eventemitter3": "^5.0.1",
        "handlebars": "^4.7.8",
        "shell-quote": "^1.8.1",
        "string-width": "^7.2.0",
        "strip-ansi": "^7.1.0",
        "vite-plugin-node-polyfills": "^0.22.0",
        "yargs": "^17.7.2",
        "yargs-parser": "^21.1.1"
    },
    "description": "A CLI prototyping library",
    "keywords": [
        "cli",
        "terminal",
        "prototype",
        "console"
    ],
    "author": "dgtlntv",
    "license": "GPL-3.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/dgtlntv/protostar.git"
    }
}
